APP_ENV=local
APP_NAME=polymarket-bot
APP_HOST=0.0.0.0
APP_PORT=8000
DASHBOARD_PORT=8501
LOG_LEVEL=INFO
LOG_FORMAT=json

PROJECT_ROOT=/app
RESOURCES_DIR=/app/resources
OBSIDIAN_VAULT_DIR=/app/obsidian-vault
EXTERNAL_AGENTS_DIR=/app/external-agents

POSTGRES_DB=polymarket
POSTGRES_USER=polymarket
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+asyncpg://polymarket:change-me@postgres:5432/polymarket

REDIS_URL=redis://redis:6379/0
QDRANT_URL=http://qdrant:6333

POLYMARKET_GAMMA_API_URL=https://gamma-api.polymarket.com
POLYMARKET_DATA_API_URL=https://data-api.polymarket.com
POLYMARKET_CLOB_API_URL=https://clob.polymarket.com
POLYMARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws
POLYMARKET_HTTP_TIMEOUT_SECONDS=20
POLYMARKET_MARKETS_PAGE_LIMIT=100
POLYMARKET_DEFAULT_ORDERBOOK_INTERVAL_SECONDS=5

N8N_IMAGE=docker.n8n.io/n8nio/n8n:2.19.5
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_ENCRYPTION_KEY=replace-with-a-long-random-key
N8N_USER_MANAGEMENT_JWT_SECRET=replace-with-a-long-random-secret
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me
N8N_WEBHOOK_URL=http://localhost:5678
N8N_PAYLOAD_SIZE_MAX=16
N8N_WORKER_CONCURRENCY=5

POLYBOT_AUTOMATION_SECRET=replace-with-shared-webhook-secret
POLYBOT_DAILY_MARKET_ID=
POLYBOT_DAILY_STRATEGY=wide-spread-mean-reversion
POLYBOT_DAILY_DECISION_MODE=hybrid
POLYBOT_DAILY_LIMIT=5000
POLYBOT_DRAWDOWN_ALERT_THRESHOLD=0.2
POLYBOT_FILL_RATE_ALERT_THRESHOLD=0.3
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=replace-with-telegram-bot-token
TELEGRAM_CHAT_ID=replace-with-telegram-chat-id
TELEGRAM_NOTIFICATIONS=true
LIVE_TRADING_ENABLED=false
LIVE_EXECUTION_MODE=DISABLED
MAX_ORDER_SIZE_USD=1
MAX_DAILY_LOSS_USD=5
MAX_OPEN_POSITIONS=2
KILL_SWITCH_ENABLED=true
REQUIRE_MANUAL_CONFIRMATION=true
POLYMARKET_PRIVATE_KEY=
POLYMARKET_FUNDER_ADDRESS=
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
